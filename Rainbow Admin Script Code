local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- Only allow this user
if player.Name ~= "moou408" then
	return
end

-- Create GUI
local gui = Instance.new("ScreenGui")
gui.Name = "RainbowAdmin"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Parent = gui
frame.Size = UDim2.new(0, 450, 0, 280)
frame.Position = UDim2.new(0.5, -225, 0.5, -140)
frame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
frame.BorderSizePixel = 0

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 12)
corner.Parent = frame

local stroke = Instance.new("UIStroke")
stroke.Thickness = 3
stroke.Parent = frame

local title = Instance.new("TextLabel")
title.Parent = frame
title.Size = UDim2.new(1, 0, 0, 45)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.Text = "RAINBOW ADMIN PANEL"
title.TextScaled = true

local info = Instance.new("TextLabel")
info.Parent = frame
info.Size = UDim2.new(1, -20, 0, 30)
info.Position = UDim2.new(0, 10, 0, 55)
info.BackgroundTransparency = 1
info.Font = Enum.Font.Gotham
info.TextScaled = true
info.Text = "Logged in as: "..player.Name

local buttonNames = {
	"Fly",
	"Noclip",
	"Speed",
	"Jump",
	"God",
	"Invisible"
}

for i, name in ipairs(buttonNames) do
	local b = Instance.new("TextButton")
	b.Parent = frame
	b.Size = UDim2.new(0, 190, 0, 40)

	local row = math.floor((i-1)/2)
	local col = (i-1)%2

	b.Position = UDim2.new(0, 25 + col*210, 0, 100 + row*55)
	b.Text = name
	b.Font = Enum.Font.GothamBold
	b.TextScaled = true
	b.BorderSizePixel = 0

	local c = Instance.new("UICorner")
	c.Parent = b

	-- Placeholder action
	b.MouseButton1Click:Connect(function()
		print(name .. " clicked")
	end)
end

-- Rainbow animation
RunService.RenderStepped:Connect(function()
	local hue = (tick() * 0.2) % 1
	local color = Color3.fromHSV(hue, 1, 1)

	stroke.Color = color
	title.TextColor3 = color

	for _, v in ipairs(frame:GetChildren()) do
		if v:IsA("TextButton") then
			v.BackgroundColor3 = color
			v.TextColor3 = Color3.new(1, 1, 1)
		end
	end
end)
